# Database
DATABASE_URL=postgresql://user:password@localhost/dbname

# Tidal Data (FES2022b)
# Local: ../data/fes2022b/
# Production (R2): s3://better-image-s2/fes2022b/
FES2022_DATA_PATH=s3://better-image-s2/fes2022b/
S3_ENDPOINT_URL=https://2913b7b59a083fae612f6ea49e69a8ad.eu.r2.cloudflarestorage.com

# Cloudflare R2 Credentials (S3 Compatible API)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Optional: Set region to auto or a specific one if needed by your provider
# AWS_DEFAULT_REGION=auto

# Settings for Authentication (Required for login)
SESSION_SECRET=coastal-session-secret-change-in-prod
JWT_SECRET_KEY=coastal-sentinel-dev-secret-key-change-in-prod
FRONTEND_URL=http://localhost:5173

# OIDC Providers (Needed for Copernicus Data download)
# Create a Copernicus Data Space Ecosystem (CDSE) client at identity.dataspace.copernicus.eu
COPERNICUS_CLIENT_ID=your_cdse_client_id
COPERNICUS_CLIENT_SECRET=your_cdse_client_secret

# Optional: Google, GitHub
# GOOGLE_CLIENT_ID=...
# GITHUB_CLIENT_ID=...
